generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SemesterType {
  ODD
  EVEN
}

enum AgendaStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  EMPTY
}

enum AttendanceStatus {
  PRESENT
  SICK
  EXCUSED
  ABSENT
}

enum AttendanceState {
  DRAFT
  SUBMITTED
  APPROVED
  CORRECTION_REQUESTED
  CORRECTED
  LOCKED
  VOID
}

enum GuardianRelation {
  FATHER
  MOTHER
  GUARDIAN
  OTHER
}

enum Gender {
  MALE
  FEMALE
}

enum NotificationChannel {
  WHATSAPP
  TELEGRAM
  EMAIL
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum FeeFrequency {
  ONCE
  MONTHLY
  SEMESTER
  YEARLY
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIAL
  PAID
  OVERDUE
  VOID
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  FAILED
  CANCELLED
  REFUNDED
}

enum PaymentMethodType {
  CASH
  BANK_TRANSFER
  VIRTUAL_ACCOUNT
  EWALLET
  QRIS
  OTHER
}

enum LoginAuditStatus {
  SUCCESS
  FAILED
  LOCKED
}

model User {
  id                   String         @id @default(uuid()) @db.Uuid
  email                String         @unique
  username             String?        @unique
  password             String
  name                 String
  roles                UserRole[]
  refreshTokens        RefreshToken[]
  passwordResetTokens  PasswordResetToken[]
  loginAudits          LoginAudit[]
  submittedAttendances Attendance[]   @relation("AttendanceSubmittedBy")
  approvedAttendances  Attendance[]   @relation("AttendanceApprovedBy")
  correctedAttendances Attendance[]   @relation("AttendanceCorrectedBy")
  lockedAttendances    Attendance[]   @relation("AttendanceLockedBy")
  receivedPayments     Payment[]      @relation("PaymentReceivedBy")
  failedLoginCount     Int            @default(0)
  lockedUntil          DateTime?
  lastLoginAt          DateTime?
  passwordChangedAt    DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  deletedAt            DateTime?

  @@index([lockedUntil])
}

model RefreshToken {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @db.Uuid
  tokenHash     String    @unique
  expiresAt     DateTime
  revokedAt     DateTime?
  revokedReason String?
  user          User      @relation(fields: [userId], references: [id])
  createdAt     DateTime  @default(now())

  @@index([userId, expiresAt])
  @@index([userId, revokedAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  user      User      @relation(fields: [userId], references: [id])
  createdAt DateTime  @default(now())

  @@index([userId, expiresAt])
}

model LoginAudit {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String?          @db.Uuid
  email     String
  status    LoginAuditStatus
  ipAddress String?
  userAgent String?
  reason    String?
  user      User?            @relation(fields: [userId], references: [id])
  createdAt DateTime         @default(now())

  @@index([email, createdAt])
  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model Role {
  id          String           @id @default(uuid()) @db.Uuid
  name        String           @unique
  users       UserRole[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Permission {
  id    String           @id @default(uuid()) @db.Uuid
  key   String           @unique
  roles RolePermission[]
}

model UserRole {
  userId String @db.Uuid
  roleId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String     @db.Uuid
  permissionId String     @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

model SchoolYear {
  id          String              @id @default(uuid()) @db.Uuid
  name        String              @unique
  startsAt    DateTime
  endsAt      DateTime
  semesters   Semester[]
  classes     Class[]
  enrollments StudentEnrollment[]
  schedules   Schedule[]
  agendas     DailyAgenda[]
  feeTypes    FeeType[]
  invoices    Invoice[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  deletedAt   DateTime?
}

model Semester {
  id           String        @id @default(uuid()) @db.Uuid
  schoolYearId String        @db.Uuid
  type         SemesterType
  startsAt     DateTime
  endsAt       DateTime
  schoolYear   SchoolYear    @relation(fields: [schoolYearId], references: [id])
  schedules    Schedule[]
  agendas      DailyAgenda[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  @@unique([schoolYearId, type])
  @@index([schoolYearId])
}

model Class {
  id           String              @id @default(uuid()) @db.Uuid
  schoolYearId String              @db.Uuid
  homeroomTeacherId String?         @db.Uuid
  name         String
  code         String?
  grade        String?
  schoolYear   SchoolYear          @relation(fields: [schoolYearId], references: [id])
  homeroomTeacher Teacher?          @relation("ClassHomeroomTeacher", fields: [homeroomTeacherId], references: [id])
  enrollments  StudentEnrollment[]
  schedules    Schedule[]
  agendas      DailyAgenda[]
  attendances  Attendance[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  deletedAt    DateTime?

  @@unique([schoolYearId, name])
  @@unique([schoolYearId, code])
  @@index([schoolYearId])
  @@index([homeroomTeacherId])
}

model Subject {
  id        String        @id @default(uuid()) @db.Uuid
  name      String
  code      String?       @unique
  isActive  Boolean       @default(true)
  schedules Schedule[]
  agendas   DailyAgenda[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  deletedAt DateTime?
}

model Teacher {
  id              String        @id @default(uuid()) @db.Uuid
  name            String
  nip             String?       @unique
  nuptk           String?       @unique
  email           String?       @unique
  phone           String?
  telegramId      String?
  isActive        Boolean       @default(true)
  schedules       Schedule[]
  agendas         DailyAgenda[]
  homeroomClasses Class[]       @relation("ClassHomeroomTeacher")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  @@index([phone])
  @@index([telegramId])
  @@index([isActive])
}

model Student {
  id              String              @id @default(uuid()) @db.Uuid
  name            String
  nis             String?             @unique
  nisn            String?             @unique
  gender          Gender?
  birthDate       DateTime?           @db.Date
  phone           String?
  isActive        Boolean             @default(true)
  enrollments     StudentEnrollment[]
  guardians       StudentGuardian[]
  attendanceItems AttendanceItem[]
  invoices        Invoice[]
  payments        Payment[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  deletedAt       DateTime?

  @@index([phone])
  @@index([isActive])
}

model Guardian {
  id         String            @id @default(uuid()) @db.Uuid
  name       String
  phone      String?
  telegramId String?
  email      String?
  address    String?
  isActive   Boolean           @default(true)
  students   StudentGuardian[]
  invoices   Invoice[]
  payments   Payment[]
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  deletedAt  DateTime?

  @@index([phone])
  @@index([telegramId])
  @@index([email])
  @@index([isActive])
}

model StudentGuardian {
  id         String           @id @default(uuid()) @db.Uuid
  studentId  String           @db.Uuid
  guardianId String           @db.Uuid
  relation   GuardianRelation
  isPrimary  Boolean          @default(false)
  student    Student          @relation(fields: [studentId], references: [id])
  guardian   Guardian         @relation(fields: [guardianId], references: [id])
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  deletedAt  DateTime?

  @@unique([studentId, guardianId])
  @@index([studentId, isPrimary])
  @@index([guardianId])
}

model StudentEnrollment {
  id              String           @id @default(uuid()) @db.Uuid
  studentId       String           @db.Uuid
  classId         String           @db.Uuid
  schoolYearId    String           @db.Uuid
  isActive        Boolean          @default(true)
  startedAt       DateTime         @default(now())
  endedAt         DateTime?
  student         Student          @relation(fields: [studentId], references: [id])
  class           Class            @relation(fields: [classId], references: [id])
  schoolYear      SchoolYear       @relation(fields: [schoolYearId], references: [id])
  attendanceItems AttendanceItem[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?

  @@unique([studentId, classId, schoolYearId])
  @@index([studentId, schoolYearId])
  @@index([classId, isActive])
  @@index([schoolYearId, isActive])
}

model Schedule {
  id           String        @id @default(uuid()) @db.Uuid
  schoolYearId String        @db.Uuid
  semesterId   String        @db.Uuid
  classId      String        @db.Uuid
  subjectId    String        @db.Uuid
  teacherId    String        @db.Uuid
  dayOfWeek    Int
  startsAt     String
  endsAt       String
  room         String?
  isActive     Boolean       @default(true)
  schoolYear   SchoolYear    @relation(fields: [schoolYearId], references: [id])
  semester     Semester      @relation(fields: [semesterId], references: [id])
  class        Class         @relation(fields: [classId], references: [id])
  subject      Subject       @relation(fields: [subjectId], references: [id])
  teacher      Teacher       @relation(fields: [teacherId], references: [id])
  agendas      DailyAgenda[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  @@index([schoolYearId, semesterId])
  @@index([classId, dayOfWeek])
  @@index([teacherId, dayOfWeek])
  @@index([isActive])
}

model DailyAgenda {
  id           String       @id @default(uuid()) @db.Uuid
  scheduleId   String?      @db.Uuid
  schoolYearId String       @db.Uuid
  semesterId   String       @db.Uuid
  classId      String       @db.Uuid
  subjectId    String       @db.Uuid
  teacherId    String       @db.Uuid
  date         DateTime     @db.Date
  status       AgendaStatus @default(SCHEDULED)
  schedule     Schedule?    @relation(fields: [scheduleId], references: [id])
  schoolYear   SchoolYear   @relation(fields: [schoolYearId], references: [id])
  semester     Semester     @relation(fields: [semesterId], references: [id])
  class        Class        @relation(fields: [classId], references: [id])
  subject      Subject      @relation(fields: [subjectId], references: [id])
  teacher      Teacher      @relation(fields: [teacherId], references: [id])
  attendance   Attendance?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([scheduleId, date])
  @@index([date, status])
  @@index([schoolYearId, semesterId])
  @@index([classId, date])
  @@index([teacherId, date])
}

model Attendance {
  id             String           @id @default(uuid()) @db.Uuid
  agendaId       String           @unique @db.Uuid
  classId        String           @db.Uuid
  state          AttendanceState  @default(DRAFT)
  startedAt      DateTime?
  submittedAt    DateTime?
  submittedById  String?          @db.Uuid
  approvedAt     DateTime?
  approvedById   String?          @db.Uuid
  correctionAt   DateTime?
  correctedById  String?          @db.Uuid
  lockedAt       DateTime?
  lockedById     String?          @db.Uuid
  endedAt        DateTime?
  notes          String?
  correctionNote String?
  agenda         DailyAgenda      @relation(fields: [agendaId], references: [id])
  class          Class            @relation(fields: [classId], references: [id])
  submittedBy    User?            @relation("AttendanceSubmittedBy", fields: [submittedById], references: [id])
  approvedBy     User?            @relation("AttendanceApprovedBy", fields: [approvedById], references: [id])
  correctedBy    User?            @relation("AttendanceCorrectedBy", fields: [correctedById], references: [id])
  lockedBy       User?            @relation("AttendanceLockedBy", fields: [lockedById], references: [id])
  items          AttendanceItem[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([classId])
  @@index([state])
  @@index([classId, state])
  @@index([submittedById])
  @@index([approvedById])
  @@index([correctedById])
  @@index([lockedById])
}

model AttendanceItem {
  id           String            @id @default(uuid()) @db.Uuid
  attendanceId String            @db.Uuid
  studentId    String            @db.Uuid
  enrollmentId String            @db.Uuid
  status       AttendanceStatus
  notes        String?
  attendance   Attendance        @relation(fields: [attendanceId], references: [id])
  student      Student           @relation(fields: [studentId], references: [id])
  enrollment   StudentEnrollment @relation(fields: [enrollmentId], references: [id])
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@unique([attendanceId, studentId])
  @@unique([attendanceId, enrollmentId])
  @@index([studentId])
  @@index([enrollmentId])
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @db.Uuid
  action     String
  entityType String
  entityId   String
  before     Json?
  after      Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
}

model NotificationLog {
  id            String              @id @default(uuid()) @db.Uuid
  channel       NotificationChannel
  status        NotificationStatus  @default(PENDING)
  recipient     String
  recipientName String?
  subject       String?
  message       String
  templateKey   String?
  dedupeKey     String?             @unique
  entityType    String?
  entityId      String?
  attempts      Int                 @default(0)
  lastError     String?
  sentAt        DateTime?
  failedAt      DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([status, createdAt])
  @@index([channel, status])
  @@index([entityType, entityId])
}

model NotificationTemplate {
  id        String              @id @default(uuid()) @db.Uuid
  key       String              @unique
  name      String
  channel   NotificationChannel
  subject   String?
  body      String
  isActive  Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  deletedAt DateTime?

  @@index([channel, isActive])
}

model FeeType {
  id           String       @id @default(uuid()) @db.Uuid
  schoolYearId String?      @db.Uuid
  name         String
  code         String       @unique
  description  String?
  amount       Decimal      @db.Decimal(14, 2)
  frequency    FeeFrequency @default(ONCE)
  isActive     Boolean      @default(true)
  schoolYear   SchoolYear?  @relation(fields: [schoolYearId], references: [id])
  invoices     Invoice[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  @@index([schoolYearId, isActive])
  @@index([frequency])
}

model PaymentMethod {
  id          String            @id @default(uuid()) @db.Uuid
  name        String
  code        String            @unique
  type        PaymentMethodType
  provider    String?
  accountName String?
  accountNo   String?
  isActive    Boolean           @default(true)
  payments    Payment[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deletedAt   DateTime?

  @@index([type, isActive])
}

model Invoice {
  id            String        @id @default(uuid()) @db.Uuid
  invoiceNumber String        @unique
  feeTypeId     String        @db.Uuid
  studentId     String        @db.Uuid
  guardianId    String?       @db.Uuid
  schoolYearId  String?       @db.Uuid
  period        String?
  amount        Decimal       @db.Decimal(14, 2)
  paidAmount    Decimal       @default(0) @db.Decimal(14, 2)
  status        InvoiceStatus @default(DRAFT)
  issuedAt      DateTime?
  dueAt         DateTime?
  paidAt        DateTime?
  voidedAt      DateTime?
  notes         String?
  feeType       FeeType       @relation(fields: [feeTypeId], references: [id])
  student       Student       @relation(fields: [studentId], references: [id])
  guardian      Guardian?     @relation(fields: [guardianId], references: [id])
  schoolYear    SchoolYear?   @relation(fields: [schoolYearId], references: [id])
  payments      Payment[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?

  @@index([studentId, status])
  @@index([guardianId, status])
  @@index([schoolYearId, status])
  @@index([feeTypeId])
  @@index([dueAt, status])
}

model Payment {
  id              String        @id @default(uuid()) @db.Uuid
  invoiceId       String        @db.Uuid
  studentId       String        @db.Uuid
  guardianId      String?       @db.Uuid
  paymentMethodId String        @db.Uuid
  receivedById    String?       @db.Uuid
  amount          Decimal       @db.Decimal(14, 2)
  status          PaymentStatus @default(PENDING)
  paidAt          DateTime?
  confirmedAt     DateTime?
  referenceNo     String?
  notes           String?
  invoice         Invoice       @relation(fields: [invoiceId], references: [id])
  student         Student       @relation(fields: [studentId], references: [id])
  guardian        Guardian?     @relation(fields: [guardianId], references: [id])
  paymentMethod   PaymentMethod @relation(fields: [paymentMethodId], references: [id])
  receivedBy      User?         @relation("PaymentReceivedBy", fields: [receivedById], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  @@index([invoiceId, status])
  @@index([studentId, status])
  @@index([guardianId, status])
  @@index([paymentMethodId])
  @@index([receivedById])
  @@index([referenceNo])
}
